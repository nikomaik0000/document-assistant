@@ -0,0 +1,33 @@
+/**
+ * jscanify 沒有提供官方型別定義。
+ * 我們只使用 "jscanify/client" 這個瀏覽器安全的進入點（純 UMD，不依賴 Node 的 canvas/jsdom），
+ * 因此只針對這個子路徑宣告最小必要的型別。
+ */
+declare module "jscanify/client" {
+  interface JscanifyCorners {
+    topLeftCorner: { x: number; y: number };
+    topRightCorner: { x: number; y: number };
+    bottomLeftCorner: { x: number; y: number };
+    bottomRightCorner: { x: number; y: number };
+  }
+
+  // eslint-disable-next-line @typescript-eslint/no-explicit-any
+  type CvMat = any;
+  type JscanifyImage = HTMLImageElement | HTMLCanvasElement;
+
+  export default class jscanify {
+    constructor();
+    findPaperContour(img: CvMat): CvMat;
+    getCornerPoints(contour: CvMat): JscanifyCorners;
+    highlightPaper(
+      image: JscanifyImage,
+      options?: { color?: string; thickness?: number }
+    ): HTMLCanvasElement;
+    extractPaper(
+      image: JscanifyImage,
+      resultWidth: number,
+      resultHeight: number,
+      cornerPoints?: JscanifyCorners
+    ): HTMLCanvasElement | null;
+  }
+}
