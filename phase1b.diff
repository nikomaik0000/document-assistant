+++ b/lib/scanner/opencvLoader.ts
@@ -0,0 +1,73 @@
+/**
+ * OpenCV.js（@techstark/opencv-js）與 jscanify 的懶載入器。
+ *
+ * 設計重點：
+ * - 兩者體積都不小（OpenCV.js 的 wasm 尤其大），因此用動態 import，
+ *   只有在使用者真的上傳圖片、需要校正時才會下載／初始化，不影響首頁載入速度。
+ * - 用 module-level 變數做 singleton，避免使用者連續上傳多批圖片時重複初始化。
+ * - jscanify 讀取的是 "jscanify/client" 這個瀏覽器安全的進入點（純 UMD，無 Node 依賴），
+ *   而不是套件預設的 "jscanify"（那個進入點是給 Node.js 用的，依賴 canvas/jsdom，
+ *   直接匯入會讓 Next.js 打包失敗）。
+ * - jscanify 的程式碼內部直接參照全域變數 cv（例如 `new cv.Mat()`），
+ *   所以載入 OpenCV.js 之後，必須手動把它掛到 window.cv 上，jscanify 才抓得到。
+ */
+import type jscanifyCtor from "jscanify/client";
+
+// eslint-disable-next-line @typescript-eslint/no-explicit-any
+type CvNamespace = any;
+
+declare global {
+  interface Window {
+    cv?: CvNamespace;
+  }
+}
+
+let cvPromise: Promise<CvNamespace> | null = null;
+let scannerPromise: Promise<InstanceType<typeof jscanifyCtor>> | null = null;
+
+async function loadOpenCv(): Promise<CvNamespace> {
+  if (typeof window === "undefined") {
+    throw new Error("OpenCV.js 只能在瀏覽器環境載入");
+  }
+
+  if (!cvPromise) {
+    cvPromise = (async () => {
+      const cvModule = (await import("@techstark/opencv-js")).default as
+        | CvNamespace
+        | Promise<CvNamespace>;
+
+      let cv: CvNamespace;
+      if (cvModule instanceof Promise) {
+        cv = await cvModule;
+      } else if (cvModule.Mat) {
+        // 部分版本在模組載入當下就已經 ready
+        cv = cvModule;
+      } else {
+        cv = await new Promise<CvNamespace>((resolve) => {
+          cvModule.onRuntimeInitialized = () => resolve(cvModule);
+        });
+      }
+
+      window.cv = cv;
+      return cv;
+    })();
+  }
+
+  return cvPromise;
+}
+
+/**
+ * 取得已初始化的 jscanify scanner 實例。
+ * 對外唯一應該呼叫的函式；OpenCV 的載入細節完全封裝在這裡。
+ */
+export async function getScanner(): Promise<InstanceType<typeof jscanifyCtor>> {
+  if (!scannerPromise) {
+    scannerPromise = (async () => {
+      await loadOpenCv();
+      const JscanifyCtor = (await import("jscanify/client")).default;
+      return new JscanifyCtor();
+    })();
+  }
+
+  return scannerPromise;
+}
